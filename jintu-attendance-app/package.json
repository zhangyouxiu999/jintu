{
  "name": "jintu-attendance-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "tsc -b && npx vite build",
    "lint": "eslint . --max-warnings 0",
    "preview": "npx vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cap:sync": "npm run build && npx cap sync",
    "ios": "npm run cap:sync && npx cap open ios",
    "android": "npm run cap:sync && npx cap open android",
    "apk:debug": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "apk:release": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease",
    "apk:serve": "bash scripts/serve-apk.sh"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/clipboard": "^6.0.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/share": "^6.0.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tamagui/config": "^1.144.4",
    "@tamagui/vite-plugin": "^1.144.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native-web": "^0.21.2",
    "react-router-dom": "^6.30.0",
    "tailwind-merge": "^2.5.4",
    "tamagui": "^1.144.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.52.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11"
  }
}
